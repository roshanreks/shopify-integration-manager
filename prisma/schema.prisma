generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ShopifySession {
  id          String   @id
  shop        String
  state       String?
  isOnline    Boolean  @default(false)
  scope       String?
  expires     DateTime?
  accessToken String?
  userId      BigInt?
  firstName   String?
  lastName    String?
  email       String?
  accountOwner Boolean @default(false)
  locale      String?
  collaborator Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop])
  @@map("shopify_sessions")
}

model Client {
  id           String   @id @default(uuid())
  name         String
  storeUrl     String
  storeName    String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  apiConfigs   ApiConfig[]

  @@map("clients")
}

model ApiConfig {
  id              String   @id @default(uuid())
  name            String
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  scopes          String[]
  apiType         String   @default("admin_graphql")
  oauthFlow       String   @default("authorization_code")
  status          String   @default("pending")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tokens          Token[]
  installGuide    Json?

  @@map("api_configs")
  @@index([clientId])
}

model Token {
  id              String    @id @default(uuid())
  configId        String
  config          ApiConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  accessToken     String
  refreshToken    String?
  grantedScopes   String[]
  expiresAt       DateTime?
  isActive        Boolean   @default(true)

  shopDomain      String
  installedAt     DateTime  @default(now())
  lastUsedAt      DateTime?
  needsRefresh    Boolean   @default(false)

  @@map("tokens")
  @@index([configId])
  @@index([isActive])
}
